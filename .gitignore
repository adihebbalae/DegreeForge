# =========================
# Agent System Files
# =========================
# These are the AI agent orchestration files.
# They should NOT be committed to the actual project repository.
# The boilerplate template repo keeps them; cloned projects ignore them.

# Agent system files (session state + boilerplate — not project code)
.agents/
.claude/
.kiro/
.github/agents/
.github/copilot/
.github/prompts/
.github/skills/
.github/scripts/
.github/copilot-instructions.md

# =========================
# Standard Ignores
# =========================

# Dependencies
node_modules/
vendor/
__pycache__/
*.pyc
.venv/
venv/

# Build outputs
dist/
build/
.next/
out/

# Environment & secrets
.env
.env.local
.env.*.local

# IDE
.vscode/settings.json
.vscode/mcp.json
.idea/
.obsidian/

# OS
.DS_Store
Thumbs.db

# =========================
# Development / Planning
# =========================
.dev/
_dev/

# =========================
# DegreeForge — UT session cookie (TASK-053 opt-in auth scrape)
# NEVER commit these — they contain your personal EID session
scripts/sections/.ut-session
*.ut-session

# DegreeForge Data Pipeline
# =========================
# Large data sources (not needed in git — reproducible via scripts)
scraped_data_corpus/
utgradesdist_21-26/
UT_Grade_Parser/

# Logs
*.log
npm-debug.log*

# Local Ollama prompt cache + fine-tune dataset (do not commit)
packages/server/ollama_log/

# Local Claude Code worktrees
.claude/worktrees/

# Playwright MCP session snapshots (temp, regenerated each session)
.playwright-mcp/

# Cursor IDE (superseded by Claude Code hooks)
.cursor/

# Playwright artifacts (reports, traces); keep checked-in baselines in __screenshots__
test-results/
packages/client/test-results/
packages/client/playwright-report/
packages/client/blob-report/
