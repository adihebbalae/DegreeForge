{
  "name": "degreeforge",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "node -e \"try { require('child_process').execSync('taskkill /F /IM ollama.exe', {stdio: 'ignore'}) } catch(e) {}\"",
    "dev": "concurrently \"ollama serve\" \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "build": "npm run build --workspace=packages/client",
    "test": "npm test --workspaces --if-present",
    "fetch:sections": "tsx scripts/sections/fetch-term.ts",
    "fetch:syllabi": "tsx scripts/syllabi/fetch-syllabi.ts",
    "aggregate:offerings": "tsx scripts/sections/aggregate-offerings.ts",
    "scrape:audit": "tsx scripts/sections/scrape-audit.ts",
    "build:catalog": "tsx scripts/catalog/build-catalog.ts",
    "privacy:paths": "node scripts/security/check-protected-paths.mjs --tracked",
    "privacy:secrets": "node scripts/security/check-secrets.mjs --tracked",
    "privacy:check": "npm run privacy:paths && npm run privacy:secrets",
    "privacy:staged": "node scripts/security/check-protected-paths.mjs --staged && node scripts/security/check-secrets.mjs --staged",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File scripts/security/install-git-hooks.ps1"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "cheerio": "1.2.0",
    "concurrently": "^9.0.0",
    "pdf-parse": "1.1.1"
  }
}
