{
  "name": "degreeforge",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "predev": "node -e \"try { require('child_process').execSync('taskkill /F /IM ollama.exe', {stdio: 'ignore'}) } catch(e) {}\"",
    "dev": "concurrently \"ollama serve\" \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "build": "npm run build --workspace=packages/client",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
