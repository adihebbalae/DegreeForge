# DegreeForge Environment Variables
# Copy this file to .env and fill in your values.
# For production deployments, see .env.production.example.

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Local dev — choose ONE of the following three options (never combine 1 and 2):
#   1. Set ANTHROPIC_API_KEY (cheapest approach: use a dev key)
#   2. Run `ant auth login` — no key needed; SDK resolves the OAuth profile
#      from ~/.config/anthropic/ automatically (ANTHROPIC_API_KEY not required)
#   3. Set ANTHROPIC_AUTH_TOKEN directly (bearer token from `ant auth login`)
#
# WARNING: do NOT set both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN — the API
#   rejects requests that present both credentials simultaneously.
ANTHROPIC_API_KEY=your_key_here

# Chat model. Code default is claude-haiku-4-5 (cheapest). For the beta we
# recommend Sonnet 4.6 — better tool-following + explanations, and it caches at
# a 1024-token prefix (Haiku only caches at 4096). Switch back to Haiku anytime
# to stretch budget: ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Invite beta access gate ──────────────────────────────────────────────────
# Set in production to gate the invite beta; leave unset for local dev (no-op).
# When set, all AI endpoints require the request header `x-access-code` to
# equal this value. Generate with: openssl rand -hex 32
# BETA_ACCESS_SECRET=

# ── Cost guard ───────────────────────────────────────────────────────────────
# Per-IP, per-day cap on AI-endpoint REQUESTS (resets at UTC midnight). NOTE:
# this counts API round-trips, not user questions — one chat question can make
# several round-trips (the model chains tool calls, up to MAX_TOOL_CALLS + 1).
# The code default is 200000 (effectively OFF). For the $5 invite beta, to allow
# ~5 questions/user/day, set this to ~30.
TOKEN_CAP_DAILY=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# NOTE: the server reads CORS_ORIGIN (singular). Local dev defaults to the Vite
# server below if unset. For deploy, set this to your hosted frontend origin
# (e.g. https://degreeforge.pages.dev or your Render static URL).
CORS_ORIGIN=http://localhost:5173

# ── Supabase (only for cloud persistence / TASK-030 — NOT needed for the beta) ─
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...

# ── Clerk auth (only for TASK-030 — NOT needed for the beta) ──────────────────
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# ── Client (build-time Vite variables) ───────────────────────────────────────
# Seed the demo (Adi) profile on first run (no stored profile in localStorage).
# Set to true in development/testing to start with a populated app.
# Leave empty in prod -> new users start with a blank profile.
# VITE_SEED_DEMO_PROFILE=true

# Absolute URL of the backend server used by the client for all API calls.
# In local dev the default (http://localhost:3005) is correct — leave unset.
# In production, set this to your deployed backend origin so the static client
# can reach the server (e.g. https://api.degreeforge.io). This is a build-time
# variable (VITE_ prefix); it is inlined into the JS bundle at build time and
# is NOT a secret — never put credentials here.
# VITE_SERVER_URL=https://api.degreeforge.io

# PostHog analytics + session replay + feedback surveys.
# VITE_POSTHOG_KEY is the PUBLIC project API key from posthog.com → Project Settings
# → Project API key. It is safe to expose in the JS bundle (it is not a secret).
# Leave unset for local dev — the analytics module is a no-op when the key is absent.
# Session replay and surveys are toggled in the PostHog dashboard; no extra code needed.
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com  # optional; defaults to us.i.posthog.com

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
