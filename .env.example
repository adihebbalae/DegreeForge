# DegreeForge Environment Variables
# Copy this file to .env and fill in your values.
# For production deployments, see .env.production.example.

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Local dev — choose ONE of the following three options (never combine 1 and 2):
#   1. Set ANTHROPIC_API_KEY (cheapest approach: use a dev key)
#   2. Run `ant auth login` — no key needed; SDK resolves the OAuth profile
#      from ~/.config/anthropic/ automatically (ANTHROPIC_API_KEY not required)
#   3. Set ANTHROPIC_AUTH_TOKEN directly (bearer token from `ant auth login`)
#
# WARNING: do NOT set both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN — the API
#   rejects requests that present both credentials simultaneously.
#
# ANTHROPIC_MODEL is configurable (default: claude-sonnet-4-6).
# Uncomment the line below to use the cheapest model for local testing:
# ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=your_key_here

# ── Supabase (required for production / TASK-030) ────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Clerk auth (required for production / TASK-030) ──────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
