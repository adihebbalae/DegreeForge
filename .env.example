# DegreeForge Environment Variables
# Copy this file to .env and fill in your values.
# For production deployments, see .env.production.example.

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Required for the AI chat feature. Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# ── Supabase (required for production / TASK-030) ────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Clerk auth (required for production / TASK-030) ──────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
