# DegreeForge — Production Environment Variables
# Copy to .env.production and fill in values before deploying.

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then Settings → API
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service role key (server-side only, never expose to client)
SUPABASE_ANON_KEY=eyJ...            # anon key (safe for client-side read operations)

# ── Clerk (auth) ─────────────────────────────────────────────────────────────
# Create an app at https://clerk.com, then API Keys
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins in production
CORS_ORIGINS=https://degreeforge.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Daily token cap per user (default 200000 — override per deployment tier)
TOKEN_CAP_DAILY=200000

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
