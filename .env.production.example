# DegreeForge — Production Environment Variables
# Copy to .env.production and fill in values before deploying.

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Production: set ANTHROPIC_API_KEY (metered, billed per token).
# Local dev alternative: run `ant auth login` — no key needed; the SDK picks up
#   the OAuth profile from ~/.config/anthropic/ automatically.
#
# ANTHROPIC_MODEL is configurable (default: claude-sonnet-4-6).
#   Suggest ANTHROPIC_MODEL=claude-haiku-4-5 for local testing (cheapest).
#
# WARNING: do NOT set both ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN — the API
#   rejects requests that present both credentials simultaneously.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5   # uncomment to override model

# ── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then Settings → API
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # service role key (server-side only, never expose to client)
SUPABASE_ANON_KEY=eyJ...            # anon key (safe for client-side read operations)

# ── Clerk (auth) ─────────────────────────────────────────────────────────────
# Create an app at https://clerk.com, then API Keys
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins in production
CORS_ORIGINS=https://degreeforge.vercel.app

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Daily token cap per user (default 200000 — override per deployment tier)
TOKEN_CAP_DAILY=200000

# ── Client seed (build-time Vite) ─────────────────────────────────────────────
# leave empty in prod -> new users start with a blank profile
# VITE_SEED_DEMO_PROFILE=

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
