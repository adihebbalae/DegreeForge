# Development overrides for the Vite client.
# This file is checked in — it sets dev-friendly defaults.
# Secret values (API keys) belong in .env.local (git-ignored).

# Seed the demo (Adi) profile on first run so developers see a populated app.
# Set to false (or remove) to test the blank first-run experience locally.
VITE_SEED_DEMO_PROFILE=true
